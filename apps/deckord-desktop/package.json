{
  "name": "deckord-desktop",
  "license": "MIT",
  "version": "0.1.0",
  "private": true,
  "description": "Deckord desktop shell (Electron): runs the service in-process, tray + config window.",
  "author": "atomskz",
  "main": "dist/main.cjs",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "compile": "esbuild src/main.ts --bundle --platform=node --format=cjs --external:electron --external:@napi-rs/canvas --external:ws --outfile=dist/main.cjs --sourcemap",
    "build": "pnpm run compile",
    "renderer": "pnpm --filter deckord-debug-deck build && node -e \"require('fs').rmSync('renderer',{recursive:true,force:true});require('fs').cpSync('../deckord-debug-deck/dist','renderer',{recursive:true})\"",
    "prepare:app": "pnpm run compile && pnpm run renderer",
    "start": "pnpm run prepare:app && electron .",
    "pack": "pnpm run prepare:app && electron-builder --dir",
    "dist": "pnpm run prepare:app && electron-builder"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "deckord-service": "workspace:*",
    "ws": "^8.18.0"
  },
  "//optionalDependencies": "The @napi-rs/canvas native Skia binary ships as per-OS packages. Declaring them as direct optional deps makes electron-builder collect the one matching the build host (pnpm skips the others via os/cpu). Keep the range in sync with @napi-rs/canvas above.",
  "optionalDependencies": {
    "@napi-rs/canvas-darwin-arm64": "^0.1.65",
    "@napi-rs/canvas-darwin-x64": "^0.1.65",
    "@napi-rs/canvas-linux-x64-gnu": "^0.1.65",
    "@napi-rs/canvas-win32-x64-msvc": "^0.1.65"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "deckord-debug-deck": "workspace:*",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.0",
    "typescript": "^5.7.2"
  }
}
