{
  "name": "deckord",
  "license": "MIT",
  "version": "0.1.0",
  "private": true,
  "description": "Deckord — show Discord voice channel participants on a (virtual or physical) macro deck.",
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n service,deck -c cyan,magenta \"pnpm dev:service\" \"pnpm dev:debug-deck\"",
    "dev:service": "pnpm --filter deckord-service dev",
    "dev:debug-deck": "pnpm --filter deckord-debug-deck dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
